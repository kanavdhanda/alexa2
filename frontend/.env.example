# ──────────────────────────────────────────────────────────────────
# Alexa Digital Twin — Frontend Environment Variables
# Copy this file to .env and fill in values for local development.
# All VITE_ prefixed variables are exposed to the browser bundle.
# ──────────────────────────────────────────────────────────────────

# Backend REST API base URL (no trailing slash)
VITE_BACKEND_URL=http://localhost:3001

# The home ID used for all API calls
VITE_HOME_ID=home_001

# Polling interval for anticipations / digital twin mode (milliseconds)
VITE_POLL_INTERVAL_MS=30000

# Set to "true" to enable verbose API logging in the browser console
VITE_API_DEBUG=false
