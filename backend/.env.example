# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── AWS Credentials (required for T3 + Polly TTS) ────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here

# ── Bedrock Model ─────────────────────────────────────────────────────────────
# Options: amazon.nova-micro-v1:0 (cheapest) | amazon.nova-lite-v1:0 | anthropic.claude-haiku-4-5-20251001
BEDROCK_MODEL_ID=amazon.nova-micro-v1:0

# ── Financial Safety (Goal 6) ─────────────────────────────────────────────────
# MOCK_LLM=true  → bypass Bedrock entirely, return hardcoded responses (safe for development)
# MOCK_LLM=false → use real Bedrock (requires valid AWS credentials + Bedrock access enabled)
MOCK_LLM=true

# ── Amazon Polly TTS ─────────────────────────────────────────────────────────
# Voice options: kajal (Indian English, neural), aditi (Hindi), raveena (Indian English)
POLLY_DEFAULT_VOICE=kajal

# ── Amazon S3 (optional, only needed for Transcribe STT via file upload) ──────
# S3_BUCKET=your-bucket-name-here

# ── Transcribe STT (optional — browser Web Speech API is the demo alternative) ─
# Leave blank to use browser Web Speech API (recommended for hackathon demo)
# TRANSCRIBE_LANGUAGE=en-IN
